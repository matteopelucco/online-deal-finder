# ============================================================
# VINTED SCOUT — Variabili d'Ambiente
# Copia questo file in .env.local e compila i valori reali
# NON committare mai .env.local su git
# ============================================================

# --- Supabase ---
# Ottenibili da: https://supabase.com → Progetto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Anthropic (Claude) ---
# Ottenibile da: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Telegram Bot ---
# 1. Apri Telegram, cerca @BotFather
# 2. Invia /newbot e segui le istruzioni
# 3. Copia il token qui
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# --- Sicurezza Cron ---
# Genera un token casuale sicuro, es: openssl rand -hex 32
# Questo stesso token va configurato come secret in GitHub Actions
CRON_SECRET=cambia_questo_con_un_token_sicuro_generato_random

# --- App ---
# URL pubblico dell'app (usato dal cron per chiamare /api/scan)
NEXT_PUBLIC_APP_URL=https://vinted-scout.vercel.app

# --- Opzionale: Configurazione Vinted ---
# Intervallo minimo tra richieste a Vinted (millisecondi)
VINTED_REQUEST_DELAY_MS=2000
# Timeout richieste HTTP a Vinted (millisecondi)
VINTED_REQUEST_TIMEOUT_MS=10000
